{
  "name": "jord-jd/php-dcom",
  "type": "library",
  "description": "PHP Database Connection Object Manager",
  "keywords": [
    "database connections",
    "database",
    "mysqli",
    "pdo",
    "PHP",
    "PHP library",
    "database connection PHP library"
  ],
  "homepage": "https://github.com/Jord-JD/php-dcom",
  "license": "LGPL-3.0-only",
  "require": {
    "php": ">=5.5.9"
  },
  "autoload": {
    "psr-4": {
      "JordJD\\DCOM\\": "src/"
    }
  },
  "replace": {
    "divineomega/php-dcom": "self.version"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "3.x-dev"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^4.8 || ^9.6 || ^12.0"
  },
  "autoload-dev": {
    "psr-4": {
      "JordJD\\DCOM\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
